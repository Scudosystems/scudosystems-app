# ═══════════════════════════════════════════════════════════
# ScudoSystems — Environment Variables Example
# Copy this to .env.local and fill in your values.
# Only the Supabase vars are required to run locally.
# ═══════════════════════════════════════════════════════════

# ─── Supabase (required) ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── App ─────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://scudosystems.com
ADMIN_EMAIL=hello@scudosystems.com
NEXT_PUBLIC_ADMIN_EMAIL=hello@scudosystems.com

# ─── Stripe (optional — add when ready for payments) ─────
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_IDS_JSON={"dental":"price_...","beauty":"price_..."}
# STRIPE_JOB_OFFER_PRICE_ID=price_...   # optional if you later charge for job offers

# ─── Resend (optional — add when ready to send emails) ───
# RESEND_API_KEY=re_...

# ─── Demo Mode (local only) ──────────────────────────────
# NEXT_PUBLIC_DEMO_MODE=true
# DEMO_EMAIL=demo@scudosystem.local
# DEMO_PASSWORD=DemoPass123!
